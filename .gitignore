# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# vite / tanstack start
/.next/
/out/
/dist
/.output
/.tanstack
/.nitro
/.vinxi

# generated route tree (regenerated by the tanstack start vite plugin)
src/routeTree.gen.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
agentlink-debug.log

# env files
.env*.local
.agentlink-progress.json

# Agent Link — database backups (may contain sensitive data)
supabase/backups/

# Deno lockfiles in edge functions — the Supabase edge runtime bundles an older
# Deno that can't read newer lockfile versions; `deno check` shouldn't leave them.
supabase/functions/**/deno.lock

# agent skills
*/skills/**

# planning docs (local only)
/plans/

# typescript
*.tsbuildinfo
next-env.d.ts
