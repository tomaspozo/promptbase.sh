{
  "name": "promptbase.sh",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "supabase start && concurrently --kill-others -n resend,functions -c magenta,green \"resend-box start\" \"supabase functions serve --env-file ./.env.local\"",
    "dev:all": "supabase start && concurrently --kill-others -n next,resend,functions -c cyan,magenta,green \"next dev\" \"resend-box start\" \"supabase functions serve --env-file ./.env.local\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "resend-box": "^0.4.0",
    "@supabase/pg-delta": "1.0.0-alpha.14",
    "supabase": "2.84.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "supabase"
    ]
  }
}
