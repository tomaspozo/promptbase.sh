{
  "name": "promptbase.sh",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "vite dev",
    "dev:backend": "supabase start && concurrently --kill-others -n resend,functions -c magenta,green \"resend-box start\" \"supabase functions serve --env-file ./.env.local\"",
    "dev:all": "supabase start && concurrently --kill-others -n vite,resend,functions -c cyan,magenta,green \"vite dev\" \"resend-box start\" \"supabase functions serve --env-file ./.env.local\"",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.5",
    "@fontsource-variable/hanken-grotesk": "^5.2.5",
    "@fontsource/dm-mono": "^5.2.5",
    "@fontsource/ibm-plex-mono": "^5.2.5",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.48.1",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "resend-box": "^0.4.0",
    "@supabase/pg-delta": "1.0.0-alpha.14",
    "supabase": "2.84.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "supabase"
    ]
  }
}
