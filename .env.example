# Supabase
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Resend (https://resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Your App <noreply@yourdomain.com>

# Resend Base URL (points to local resend-box sandbox in dev; remove for production)
RESEND_BASE_URL=http://host.docker.internal:4657

APP_NAME=YourApp

# Public app URL — used by edge functions to build email links
# (approval + team invite). Dev: the Vite app on port 3000.
APP_URL=http://localhost:3000

# Supabase OAuth app (Management API) for connecting users' Supabase orgs.
# Register an OAuth app at https://supabase.com/dashboard/org/_/apps with the
# redirect URI <APP_URL>/oauth/supabase/callback. Note: NOT prefixed SUPABASE_*
# (that prefix is reserved for Supabase's own injected vars).
SB_OAUTH_CLIENT_ID=your-oauth-client-id
SB_OAUTH_SECRET=your-oauth-client-secret
# Browser-visible copy of the client id (public) for building the authorize URL.
VITE_SB_OAUTH_CLIENT_ID=your-oauth-client-id
